class TestSearchBranchSettings:
    """Tests for SearchBranchSettings."""

    @staticmethod
    def test_to_request_type_id() -> None:
        """to_request embeds the correct TYPE_ID."""
        settings = SearchBranchSettings(
            repository_id=_REPO_ID,
            search_branches=["refs/heads/main"],
        )
        assert settings.to_request().type == PolicyTypeIdRef(
            id=UUID("0517f88d-4ec5-4343-9d26-9930ebd53069")
        )

    @staticmethod
    def test_to_request_search_branches() -> None:
        """SearchBranches appears in settings."""
        branches = ["refs/heads/release/staging", "refs/heads/release/prod"]
        settings = SearchBranchSettings(
            repository_id=_REPO_ID, search_branches=branches
        )
        assert settings.to_request().settings["searchBranches"] == branches
