from uuid import UUID

from pyado.raw.policy_types import (
    BuildPolicySettings,
    CommentRequirementsSettings,
    CommitAuthorEmailValidationSettings,
    FileNameRestrictionSettings,
    FileSizeRestrictionSettings,
    GitRepositorySettings,
    MergeStrategySettings,
    MinimumReviewersSettings,
    PathLengthRestrictionSettings,
    RequiredReviewersSettings,
    ReservedNamesRestrictionSettings,
    SearchBranchSettings,
    StatusPolicySettings,
    WorkItemLinkingSettings,
)

from pyado.raw.policy import (
    PolicyConfigurationRequest,
    PolicyScopeMatchKind,
    PolicyTypeIdRef,
)

_REPO_ID = UUID("2d0a1d19-a496-4858-9c63-b7851549e7eb")
_REPO_NAME = "my-repo"
_REF_NAME = "refs/heads/main"


class TestMinimumReviewersSettings:
    """Tests for MinimumReviewersSettings."""

    @staticmethod
    def test_to_request_returns_policy_configuration_request() -> None:
        """to_request returns a PolicyConfigurationRequest."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            repository_name=_REPO_NAME,
            ref_name=_REF_NAME,
            minimum_approver_count=2,
        )
        request = settings.to_request()
        assert isinstance(request, PolicyConfigurationRequest)

    @staticmethod
    def test_to_request_type_id() -> None:
        """to_request embeds the correct TYPE_ID."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            minimum_approver_count=1,
        )
        request = settings.to_request()
        assert request.type == PolicyTypeIdRef(
            id=UUID("fa4e907d-c16b-4a4c-9dfa-4906e5d171dd")
        )

    @staticmethod
    def test_to_request_default_is_enabled_and_blocking() -> None:
        """to_request uses is_enabled=True and is_blocking=True by default."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            minimum_approver_count=1,
        )
        request = settings.to_request()
        assert request.is_enabled is True
        assert request.is_blocking is True

    @staticmethod
    def test_to_request_respects_is_enabled_false() -> None:
        """to_request uses is_enabled=False when set."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            minimum_approver_count=1,
            is_enabled=False,
        )
        assert settings.to_request().is_enabled is False

    @staticmethod
    def test_to_request_respects_is_blocking_false() -> None:
        """to_request uses is_blocking=False when set."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            minimum_approver_count=1,
            is_blocking=False,
        )
        assert settings.to_request().is_blocking is False

    @staticmethod
    def test_to_request_settings_dict_keys() -> None:
        """to_request settings dict uses camelCase keys."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            minimum_approver_count=3,
            creator_vote_counts=True,
            allow_downvotes=True,
        )
        s = settings.to_request().settings
        assert s["minimumApproverCount"] == 3
        assert s["creatorVoteCounts"] is True
        assert s["allowDownvotes"] is True

    @staticmethod
    def test_to_request_excludes_none_optional_fields() -> None:
        """Optional None fields are absent from the settings dict."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            minimum_approver_count=1,
        )
        s = settings.to_request().settings
        assert "requireVoteOnEachIteration" not in s

    @staticmethod
    def test_to_request_includes_optional_field_when_set() -> None:
        """Optional fields appear in settings when explicitly set."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            minimum_approver_count=1,
            require_vote_on_each_iteration=True,
        )
        assert settings.to_request().settings["requireVoteOnEachIteration"] is True

    @staticmethod
    def test_to_request_scope_branch() -> None:
        """to_request builds the correct branch scope."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            minimum_approver_count=1,
        )
        scope = settings.to_request().settings["scope"]
        assert scope == [
            {
                "repositoryId": str(_REPO_ID),
                "refName": _REF_NAME,
                "matchKind": "Exact",
            }
        ]

    @staticmethod
    def test_to_request_scope_prefix_match_kind() -> None:
        """to_request scope uses Prefix matchKind when specified."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            ref_name="refs/heads/release",
            match_kind=PolicyScopeMatchKind.PREFIX,
            minimum_approver_count=1,
        )
        scope = settings.to_request().settings["scope"]
        assert scope[0]["matchKind"] == "Prefix"

    @staticmethod
    def test_to_request_excludes_scope_from_settings_top_level() -> None:
        """repository_name is informational and absent from the settings dict."""
        settings = MinimumReviewersSettings(
            repository_id=_REPO_ID,
            repository_name=_REPO_NAME,
            ref_name=_REF_NAME,
            minimum_approver_count=1,
        )
        s = settings.to_request().settings
        assert "repository_name" not in s
        assert "repositoryName" not in s

    @staticmethod
    def test_type_id_class_var() -> None:
        """TYPE_ID is the known ADO policy type UUID."""
        assert (
            UUID("fa4e907d-c16b-4a4c-9dfa-4906e5d171dd")
            == MinimumReviewersSettings.TYPE_ID
        )


class TestCommentRequirementsSettings:
    """Tests for CommentRequirementsSettings."""

    @staticmethod
    def test_to_request_type_id() -> None:
        """to_request embeds the correct TYPE_ID."""
        settings = CommentRequirementsSettings(
            repository_id=_REPO_ID, ref_name=_REF_NAME
        )
        assert settings.to_request().type == PolicyTypeIdRef(
            id=UUID("c6a1889d-b943-4856-b76f-9e46bb6b0df2")
        )

    @staticmethod
    def test_to_request_scope_only_settings() -> None:
        """Settings dict contains only the scope key (no extra fields)."""
        settings = CommentRequirementsSettings(
            repository_id=_REPO_ID, ref_name=_REF_NAME
        )
        s = settings.to_request().settings
        assert list(s.keys()) == ["scope"]

    @staticmethod
    def test_to_request_default_branch_scope() -> None:
        """Default-branch project-wide scope retains null repositoryId."""
        settings = CommentRequirementsSettings(
            repository_id=None,
            ref_name=None,
            match_kind=PolicyScopeMatchKind.DEFAULT_BRANCH,
        )
        scope = settings.to_request().settings["scope"]
        assert scope[0]["matchKind"] == "DefaultBranch"
        assert scope[0]["repositoryId"] is None


