class TestMergeStrategySettings:
    """Tests for MergeStrategySettings."""

    @staticmethod
    def test_to_request_type_id() -> None:
        """to_request embeds the correct TYPE_ID (distinct from MinimumReviewers)."""
        settings = MergeStrategySettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            allow_squash=True,
        )
        assert settings.to_request().type == PolicyTypeIdRef(
            id=UUID("fa4e907d-c16b-4a4c-9dfa-4916e5d171ab")
        )

    @staticmethod
    def test_to_request_strategy_flags() -> None:
        """Set strategy flags appear in settings; unset flags are absent."""
        settings = MergeStrategySettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            allow_squash=True,
            allow_rebase_merge=True,
        )
        s = settings.to_request().settings
        assert s["allowSquash"] is True
        assert s["allowRebaseMerge"] is True
        assert "allowNoFastForward" not in s
        assert "allowRebase" not in s

    @staticmethod
    def test_type_id_differs_from_minimum_reviewers() -> None:
        """MergeStrategy and MinimumReviewers share a prefix but are distinct."""
        assert MergeStrategySettings.TYPE_ID != MinimumReviewersSettings.TYPE_ID


class TestBuildPolicySettings:
    """Tests for BuildPolicySettings."""

    @staticmethod
    def test_to_request_type_id() -> None:
        """to_request embeds the correct TYPE_ID."""
        settings = BuildPolicySettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            build_definition_id=42,
            queue_on_source_update_only=True,
            manual_queue_only=False,
        )
        assert settings.to_request().type == PolicyTypeIdRef(
            id=UUID("0609b952-1397-4640-95ec-e00a01b2c241")
        )

    @staticmethod
    def test_to_request_required_fields() -> None:
        """Required fields appear in settings with camelCase keys."""
        settings = BuildPolicySettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            build_definition_id=32,
            queue_on_source_update_only=False,
            manual_queue_only=False,
        )
        s = settings.to_request().settings
        assert s["buildDefinitionId"] == 32
        assert s["queueOnSourceUpdateOnly"] is False
        assert s["manualQueueOnly"] is False
        assert s["validDuration"] == 0.0

    @staticmethod
    def test_to_request_optional_display_name_absent_when_none() -> None:
        """display_name absent when None."""
        settings = BuildPolicySettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            build_definition_id=1,
            queue_on_source_update_only=False,
            manual_queue_only=False,
        )
        assert "displayName" not in settings.to_request().settings

    @staticmethod
    def test_to_request_optional_filename_patterns() -> None:
        """filename_patterns appears when set."""
        settings = BuildPolicySettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            build_definition_id=1,
            queue_on_source_update_only=False,
            manual_queue_only=False,
            filename_patterns=["/src/*"],
        )
        assert settings.to_request().settings["filenamePatterns"] == ["/src/*"]


class TestRequiredReviewersSettings:
    """Tests for RequiredReviewersSettings."""

    _REVIEWER = UUID("6de91b4b-5753-41e7-b7a5-05fe82cdefcc")

    @staticmethod
    def test_to_request_type_id() -> None:
        """to_request embeds the correct TYPE_ID."""
        settings = RequiredReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            required_reviewer_ids=[TestRequiredReviewersSettings._REVIEWER],
            minimum_approver_count=1,
        )
        assert settings.to_request().type == PolicyTypeIdRef(
            id=UUID("fd2167ab-b0be-447a-8ec8-39368250530e")
        )

    @staticmethod
    def test_to_request_reviewer_ids_serialized_as_strings() -> None:
        """required_reviewer_ids appear as UUID strings in settings."""
        reviewer = TestRequiredReviewersSettings._REVIEWER
        settings = RequiredReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            required_reviewer_ids=[reviewer],
            minimum_approver_count=1,
        )
        ids = settings.to_request().settings["requiredReviewerIds"]
        assert ids == [str(reviewer)]

    @staticmethod
    def test_to_request_message_absent_when_none() -> None:
        """Message absent from settings when not provided."""
        settings = RequiredReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            required_reviewer_ids=[TestRequiredReviewersSettings._REVIEWER],
            minimum_approver_count=1,
        )
        assert "message" not in settings.to_request().settings

    @staticmethod
    def test_to_request_message_present_when_set() -> None:
        """Message present in settings when set."""
        settings = RequiredReviewersSettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            required_reviewer_ids=[TestRequiredReviewersSettings._REVIEWER],
            minimum_approver_count=1,
            message="Please review",
        )
        assert settings.to_request().settings["message"] == "Please review"


class TestStatusPolicySettings:
    """Tests for StatusPolicySettings."""

    _AUTHOR_ID = UUID("d343a15d-d264-6742-a574-dd64798fc77e")

    @staticmethod
    def test_to_request_type_id() -> None:
        """to_request embeds the correct TYPE_ID."""
        settings = StatusPolicySettings(
            repository_id=_REPO_ID,
            ref_name="refs/heads/release",
            match_kind=PolicyScopeMatchKind.PREFIX,
            status_name="pre_commit",
            status_genre="test",
            author_id=TestStatusPolicySettings._AUTHOR_ID,
            invalidate_on_source_update=True,
            default_display_name="pre-commit",
        )
        assert settings.to_request().type == PolicyTypeIdRef(
            id=UUID("cbdc66da-9728-4af8-aada-9a5a32e4a226")
        )

    @staticmethod
    def test_to_request_settings_fields() -> None:
        """Settings dict contains the expected status fields."""
        author_id = TestStatusPolicySettings._AUTHOR_ID
        settings = StatusPolicySettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            status_name="lint",
            status_genre="test",
            author_id=author_id,
            invalidate_on_source_update=True,
            default_display_name="Static Code Analysis",
        )
        s = settings.to_request().settings
        assert s["statusName"] == "lint"
        assert s["statusGenre"] == "test"
        assert s["authorId"] == str(author_id)
        assert s["invalidateOnSourceUpdate"] is True
        assert s["defaultDisplayName"] == "Static Code Analysis"

    @staticmethod
    def test_to_request_filename_patterns_absent_when_none() -> None:
        """FilenamePatterns absent when not set."""
        settings = StatusPolicySettings(
            repository_id=_REPO_ID,
            ref_name=_REF_NAME,
            status_name="x",
            status_genre="test",
            author_id=TestStatusPolicySettings._AUTHOR_ID,
            invalidate_on_source_update=False,
            default_display_name="X",
        )
        assert "filenamePatterns" not in settings.to_request().settings


class TestGitRepositorySettings:
    """Tests for GitRepositorySettings."""

    @staticmethod
    def test_to_request_type_id() -> None:
        """to_request embeds the correct TYPE_ID."""
        settings = GitRepositorySettings(repository_id=_REPO_ID)
        assert settings.to_request().type == PolicyTypeIdRef(
            id=UUID("7ed39669-655c-494e-b4a0-a08b4da0fcce")
        )

    @staticmethod
    def test_to_request_repo_scope() -> None:
        """Scope contains only repositoryId for repo-level policy."""
        settings = GitRepositorySettings(repository_id=_REPO_ID)
        scope = settings.to_request().settings["scope"]
        assert scope == [{"repositoryId": str(_REPO_ID)}]

    @staticmethod
    def test_to_request_project_wide_scope_keeps_null() -> None:
        """Project-wide scope retains repositoryId: null."""
        settings = GitRepositorySettings(repository_id=None)
        scope = settings.to_request().settings["scope"]
        assert scope[0]["repositoryId"] is None

    @staticmethod
    def test_to_request_optional_fields_absent_when_none() -> None:
        """Optional None settings fields are absent from the dict."""
        settings = GitRepositorySettings(repository_id=_REPO_ID)
        s = settings.to_request().settings
        assert "enforceConsistentCase" not in s
        assert "strictVoteMode" not in s

    @staticmethod
    def test_to_request_optional_fields_present_when_set() -> None:
        """Set optional fields appear in the settings dict."""
        settings = GitRepositorySettings(
            repository_id=_REPO_ID,
            enforce_consistent_case=True,
            strict_vote_mode=False,
        )
        s = settings.to_request().settings
        assert s["enforceConsistentCase"] is True
        assert s["strictVoteMode"] is False

    @staticmethod
    def test_to_request_repository_name_excluded() -> None:
        """repository_name is informational and absent from settings."""
        settings = GitRepositorySettings(
            repository_id=_REPO_ID, repository_name=_REPO_NAME
        )
        s = settings.to_request().settings
        assert "repositoryName" not in s
        assert "repository_name" not in s


